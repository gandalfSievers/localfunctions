# localfunctions configuration
# Copy to .env and modify as needed

# Bind address
LOCAL_LAMBDA_HOST=0.0.0.0

# External API port (Invoke, List, Health)
LOCAL_LAMBDA_PORT=9600

# Runtime API port (containers connect here)
LOCAL_LAMBDA_RUNTIME_PORT=9601

# AWS region for ARN generation
LOCAL_LAMBDA_REGION=us-east-1

# AWS account ID for ARN generation
LOCAL_LAMBDA_ACCOUNT_ID=000000000000

# Path to function definitions file
LOCAL_LAMBDA_FUNCTIONS_FILE=./functions.json

# Log level (trace, debug, info, warn, error)
LOCAL_LAMBDA_LOG_LEVEL=info

# Graceful shutdown timeout in seconds
LOCAL_LAMBDA_SHUTDOWN_TIMEOUT=30

# Seconds before idle warm containers are removed
LOCAL_LAMBDA_CONTAINER_IDLE_TIMEOUT=300

# Maximum concurrent containers across all functions
LOCAL_LAMBDA_MAX_CONTAINERS=20

# Docker network name for container communication
LOCAL_LAMBDA_DOCKER_NETWORK=localfunctions

# Pull missing Docker images on startup (true/false)
# Also accepted: LOCALFUNCTIONS_PULL_IMAGES
LOCAL_LAMBDA_PULL_IMAGES=false
