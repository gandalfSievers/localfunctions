{
  "functions": {
    "python-hello": {
      "runtime": "python3.12",
      "handler": "main.handler",
      "code_path": "./python-hello",
      "timeout": 30,
      "memory_size": 128,
      "function_url_enabled": true
    },
    "python-error": {
      "runtime": "python3.12",
      "handler": "main.handler",
      "code_path": "./python-error",
      "timeout": 30,
      "memory_size": 128
    },
    "nodejs-hello": {
      "runtime": "nodejs20.x",
      "handler": "index.handler",
      "code_path": "./nodejs-hello",
      "timeout": 30,
      "memory_size": 128,
      "function_url_enabled": true
    }
  },
  "runtime_images": {
    "python3.12": "public.ecr.aws/lambda/python:3.12",
    "nodejs20.x": "public.ecr.aws/lambda/nodejs:20"
  },
  "event_source_mappings": [
    {
      "queue_url": "https://sqs.us-east-1.amazonaws.com/000000000000/traefik-test-queue",
      "function_name": "python-hello",
      "batch_size": 1,
      "endpoint_url": "https://sqs.us-east-1.amazonaws.com",
      "region": "us-east-1"
    }
  ]
}
